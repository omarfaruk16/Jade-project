# ─── Jade Platform — VPS Docker Deployment Guide ──────────────────────

# STEP 1: SSH into your VPS and clone the project
# git clone <your-repo-url> /opt/jade
# cd /opt/jade

# STEP 2: Create the .env file (REQUIRED before first run)
# Copy from the example and edit:
# cp .env.example .env
# nano .env   <-- fill in your VPS IP and generate a strong JWT secret

# ─────────────────────────────────────────────────────────────────────
# REQUIRED: Generate a strong JWT secret with this command:
#   openssl rand -hex 64
# Then paste the result into JWT_SECRET below.
# ─────────────────────────────────────────────────────────────────────

# ─── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=jade_user
POSTGRES_PASSWORD=Jade@Secure2025!
POSTGRES_DB=jade_db

# ─── Backend ─────────────────────────────────────────────────
# Replace YOUR_VPS_IP_OR_DOMAIN with your actual VPS IP or domain
BACKEND_URL=http://YOUR_VPS_IP_OR_DOMAIN:5001

# CORS: Comma-separated list of allowed frontend origins
# Example: FRONTEND_URL=http://YOUR_VPS_IP_OR_DOMAIN:3000,https://yourdomain.com
FRONTEND_URL=http://YOUR_VPS_IP_OR_DOMAIN:3000

# Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# ─── Frontend ────────────────────────────────────────────────
# Replace YOUR_VPS_IP_OR_DOMAIN with your actual VPS IP or domain
NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP_OR_DOMAIN:5001/api

# ─────────────────────────────────────────────────────────────
# ADMIN CREDENTIALS (set by seed.js on first run)
# ─────────────────────────────────────────────────────────────
# Username: admin
# Password: password123
#
# ⚠️  IMPORTANT: Change the admin password after first login!
# To change it, go to /admin/dashboard after deploying.

# ─── Cloudinary (Image/Video Storage) ─────────────────────────
CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@<your_cloud_name>
